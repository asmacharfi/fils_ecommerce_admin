# Copy to ".env" (or ".env.local") for local dev.
# On Vercel: Project → Settings → Environment Variables (set for Production + Preview).

# --- Clerk (https://dashboard.clerk.com) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# --- Database (Prisma / PostgreSQL, e.g. Neon, Supabase, Aiven) ---
# Prisma CLI (migrate, db push) still reads DATABASE_URL from prisma/schema.prisma.
DATABASE_URL=
#
# --- Aiven for PostgreSQL (Vercel / serverless) ---
# The Overview “Service URI” connects directly to Postgres (one backend connection per client).
# For Next.js on Vercel, create a PgBouncer pool and use that URI for runtime instead:
#   Console → your service → Connection pools → Add pool (mode: transaction is default)
#   Actions → Info on the pool → copy the pool URI (host is often *.aivencloud.com with a
#   different port than the primary; the path uses the *pool name* as dbname, not defaultdb).
# Put that URI in POSTGRES_PRISMA_URL or DATABASE_URL on Vercel, then redeploy.
# Keep a separate direct Service URI in DATABASE_URL for local `prisma migrate` only if you prefer,
# or run migrations from CI with DATABASE_URL pointing at the primary (defaultdb) URI.
# Pooling requires an Aiven plan that includes connection pooling (see Aiven docs).
# https://aiven.io/docs/products/postgresql/howto/manage-pool
#
# Optional pooled URL for the Next.js runtime (recommended on Vercel). If set, it is
# preferred over DATABASE_URL so serverless traffic uses a pooler and avoids P2037
# (Postgres "remaining connection slots are reserved for ... SUPERUSER").
#POSTGRES_PRISMA_URL=
#PRISMA_DATABASE_URL=
#POSTGRES_URL=
# Optional: Prisma connection pool size per server process (see lib/prismadb.ts).
# On Vercel, leave unset so it defaults to 1 — raising it multiplies DB connections across lambdas
# and triggers "remaining connection slots are reserved for … SUPERUSER" on small plans.
#DATABASE_CONNECTION_LIMIT=1
#
# Aiven / RDS: use your provider’s *transaction pooler* URI for runtime (or set POSTGRES_PRISMA_URL);
# a plain primary/direct URL will open one connection per concurrent serverless invocation.

# --- Cloudinary (https://cloudinary.com) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# --- Stripe (https://dashboard.stripe.com/apikeys) ---
STRIPE_API_KEY=
# Webhook signing secret from Stripe CLI or Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=
# Public URL of the storefront (checkout success/cancel). On Vercel use https://your-store.vercel.app
FRONTEND_STORE_URL=http://localhost:3001

# --- AI assistant (see lib/ai/create-chat-model.ts) ---
# Default: OpenAI. Set AI_PROVIDER=openrouter for OpenRouter.
#AI_PROVIDER=openai
#AI_MODEL=
#OPENAI_API_KEY=
#OPENROUTER_API_KEY=
#OPENROUTER_HTTP_REFERER=https://your-admin.vercel.app
#OPENROUTER_APP_TITLE=Admin dashboard
