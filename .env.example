# Copy to ".env" (or ".env.local") for local dev.
# On Vercel: Project → Settings → Environment Variables (set for Production + Preview).

# --- Clerk (https://dashboard.clerk.com) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
#
# Storefront JWT: use the SAME Clerk application for the public store and this admin so
# CLERK_SECRET_KEY can verify Bearer tokens on POST /api/[storeId]/checkout and GET /api/[storeId]/orders/me.
#
# Optional: comma-separated storefront origins (exact URLs) allowed as Clerk session token azp.
# Set if GET /orders/me returns 401 on Vercel Preview while signed in (e.g. https://store-git-xxx.vercel.app,https://www.yourshop.com).
#CLERK_AUTHORIZED_PARTIES=

# --- Database (Prisma / PostgreSQL) ---
#
# Neon (recommended for Vercel serverless)
# ----------------------------------------
# In Neon Console → Connect, copy TWO connection strings (same user/password):
#   1) Connection pooling ON  → host contains `…-pooler…`  (use for runtime)
#   2) Connection pooling OFF → host `ep-…` without `-pooler` (use for migrations / pg_restore)
#
# prisma/schema.prisma uses:
#   url       = env("DATABASE_URL")   → pooled Neon URI on Vercel
#   directUrl = env("DIRECT_URL")     → direct Neon URI (Prisma migrate, db push, db pull)
#
# Local dev: you can set DATABASE_URL to either pooled or direct; DIRECT_URL must always be
# the direct endpoint. If you only have one string locally, duplicate it into both vars.
DATABASE_URL=
DIRECT_URL=
#
# Optional: same pooled URI as DATABASE_URL — lib/prismadb.ts prefers this when set.
#POSTGRES_PRISMA_URL=
#PRISMA_DATABASE_URL=
#POSTGRES_URL=
#
# Serverless: keep at 1 on Vercel so each lambda opens at most one DB connection (see lib/prismadb.ts).
#DATABASE_CONNECTION_LIMIT=1
#
# Full migration checklist: docs/NEON_MIGRATION.md
#
# --- Aiven for PostgreSQL (legacy / other hosts) ---
# Free Aiven tiers may not expose connection pools; without a pooler, Vercel + Prisma can hit P2037.
# If you stay on Aiven, use a transaction pool URI for runtime when your plan supports it:
# https://aiven.io/docs/products/postgresql/howto/manage-pool

# --- Cloudinary (https://cloudinary.com) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# --- Stripe (https://dashboard.stripe.com/apikeys) ---
STRIPE_API_KEY=
# Webhook signing secret from Stripe CLI or Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=
# Public origin of the storefront (Stripe success/cancel redirects). Must match the URL shoppers use so Clerk cookies apply after checkout (same host as the store app). Include Vercel preview URLs in Clerk Dashboard → Allowed origins / redirect URLs when testing previews.
FRONTEND_STORE_URL=http://localhost:3001

# --- AI assistant (see lib/ai/create-chat-model.ts) ---
# Default: OpenAI. Set AI_PROVIDER=openrouter for OpenRouter.
# Model id (optional). OpenAI default: gpt-4o-mini. OpenRouter default (in code): openai/gpt-oss-120b:free
#AI_PROVIDER=openai
#AI_MODEL=openai/gpt-oss-120b:free
#OPENAI_API_KEY=
#OPENROUTER_API_KEY=
#OPENROUTER_HTTP_REFERER=https://your-admin.vercel.app
#OPENROUTER_APP_TITLE=Admin dashboard
